<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Loopin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- FAVICON -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,
    <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'>
    <rect width='100' height='100' rx='20' fill='%236c63ff'/>
    <polygon points='40,30 75,50 40,70' fill='white'/>
    </svg>">

    <style>
        body {
            min-height: 100vh;
            display: flex;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: #0f0f1a;
            color: white;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            background: linear-gradient(180deg, #6c63ff, #3f3d56);
            padding: 20px;
            transition: 0.3s;
            position: relative;
        }

        .sidebar.hide {
            margin-left: -260px;
        }

        .sidebar h2 {
            font-weight: bold;
            margin-bottom: 20px;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            border-radius: 12px;
            color: white;
            text-decoration: none;
            transition: 0.2s;
            font-size: 14px;
        }

        .sidebar a:hover {
            background: rgba(255,255,255,0.15);
            transform: translateX(6px);
        }

        .sidebar a.active {
            background: rgba(0,0,0,0.3);
            font-weight: 600;
        }

        /* FLOAT BUTTON */
        .menu-toggle-global {
            position: fixed;
            top: 15px;
            left: 15px;
            z-index: 999;
            background: #6c63ff;
            color: white;
            border-radius: 10px;
            padding: 8px 12px;
            cursor: pointer;
            display: none;
            box-shadow: 0 5px 15px rgba(0,0,0,0.4);
        }

        /* CONTENT */
        .content {
            flex-grow: 1;
            padding: 20px;
        }

        /* NAVBAR */
        .navbar-custom {
            background: rgba(30,30,40,0.6);
            backdrop-filter: blur(20px);
            border-radius: 15px;
            padding: 12px 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

        /* SEARCH */
        .form-control {
            border-radius: 12px;
            background: #1a1a2e;
            border: 1px solid #333;
            color: white;
        }

        .form-control:focus {
            box-shadow: 0 0 12px rgba(108,99,255,0.6);
            background: #1a1a2e;
            color: white;
        }

        /* ICON BUTTON */
        .icon-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: rgba(108,99,255,0.15);
            color: white;
            transition: 0.2s;
            text-decoration: none;
        }

        .icon-btn:hover {
            background: #6c63ff;
            transform: scale(1.08);
            box-shadow: 0 0 15px rgba(108,99,255,0.5);
        }

        .search-btn {
            width: 45px;
        }

        /* SIDEBAR CLOSED BUTTON */
        .sidebar.hide ~ .content .menu-toggle-global {
            display: block;
        }

        footer {
            margin-top: 30px;
            text-align: center;
            opacity: 0.5;
            font-size: 13px;
        }

        .top-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .toggle-btn {
            cursor: pointer;
            background: rgba(255,255,255,0.2);
            padding: 6px 12px;
            border-radius: 10px;
            margin-bottom: 10px;
        }

        /* SMOOTH */
        * {
            transition: 0.2s;
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">

        <h2>🎬 Loopin</h2>

        <div class="toggle-btn" onclick="toggleSidebar()">☰ Menü</div>

        <a asp-action="Index" asp-controller="Home" class="active">🏠 Ana Sayfa</a>
        <a asp-controller="Home" asp-action="Yukle">🎬 Video Yükle</a>
        <a asp-controller="Home" asp-action="Trendler">🔥 Trendler</a>
        <a asp-controller="Home" asp-action="BenimVideolarim">📂 Videolarım</a>
        <a asp-controller="Home" asp-action="BegenilenVideolar">❤️ Beğendiklerim</a>
        <a asp-controller="Home" asp-action="AbonelikVideolari">📺 Abonelikler</a>
        <a asp-controller="Home" asp-action="DahaSonraIzle">⏰ Daha Sonra İzle</a>
        <a asp-controller="Home" asp-action="Gecmis">📜 İzleme Geçmişi</a>

        @* ✅ Admin Panel sadece admin kullanıcıya görünür *@
        @if (Context.Session.GetString("IsAdmin") == "true")
        {
            <a asp-controller="Home" asp-action="AdminPanel">🛠 Admin Panel</a>
        }

    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- FLOAT BUTTON -->
        <div class="menu-toggle-global" onclick="toggleSidebar()">☰</div>

        <!-- NAVBAR -->
        <nav class="navbar navbar-custom mb-4 d-flex justify-content-between align-items-center">

            <!-- SEARCH -->
            <form class="d-flex w-50" asp-controller="Home" asp-action="Arama" method="get">
                <input class="form-control me-2" type="search" name="q" placeholder="Video veya kullanıcı ara..." />
                <button class="icon-btn search-btn" type="submit">🔍</button>
            </form>

            <!-- ACTIONS -->
            <div class="top-actions">

                @if (Context.Session.GetString("UserEmail") == null)
                {
                    <a class="icon-btn" href="/Home/Giris" title="Giriş">🔑</a>
                    <a class="icon-btn" href="/Home/Kayit" title="Kayıt">📝</a>
                }
                else
                {
                    <a class="icon-btn"
                       asp-controller="Home"
                       asp-action="Kullanici"
                       asp-route-id="@Context.Session.GetInt32("UserId")"
                       title="Profil">👤</a>
                    <a class="icon-btn" asp-controller="Home" asp-action="SifreDegistir" title="Şifre Değiştir">🔒</a>
                    <a class="icon-btn" href="/Home/Cikis" title="Çıkış">🚪</a>
                }

            </div>

        </nav>

        <!-- PAGE -->
        <main>
            @RenderBody()
        </main>

        <footer>
            &copy; 2026 - Loopin | Modern Video Platform
        </footer>

    </div>

    <!-- JS -->
    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("hide");
        }
    </script>

</body>
</html>
