@model List<Loopin.Models.Video>

@{
    ViewData["Title"] = "Beğendiklerim";
}

<style>
    body {
        background: radial-gradient(circle at top, #141428, #0b0b14);
        color: white;
    }

    .section-title {
        font-size: 26px;
        font-weight: 800;
        background: linear-gradient(90deg, #f472b6, #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 25px;
    }

    .video-card {
        border-radius: 18px;
        overflow: hidden;
        background: #16162a;
        transition: 0.3s ease;
        position: relative;
        border: 1px solid rgba(255,255,255,0.05);
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .video-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 30px 70px rgba(0,0,0,0.6);
        border-color: rgba(236,72,153,0.4);
    }

    .video-img {
        height: 190px;
        width: 100%;
        object-fit: cover;
        transition: 0.4s;
    }

    .video-card:hover .video-img { transform: scale(1.08); }

    .overlay {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 190px;
        background: rgba(0,0,0,0.4);
        display: flex; justify-content: center; align-items: center;
        opacity: 0; transition: 0.3s;
    }

    .video-card:hover .overlay { opacity: 1; }

    .play-icon { font-size: 44px; color: white; text-shadow: 0 0 15px rgba(255,255,255,0.4); }

    .card-body { padding: 14px; }

    .video-title { font-weight: 700; font-size: 15px; color: #f3f4f6; margin-bottom: 5px; }
    .video-desc { font-size: 12px; color: #9ca3af; height: 38px; overflow: hidden; }
    .video-meta { font-size: 12px; color: #cbd5e1; margin-top: 10px; line-height: 1.6; }

    .btn-watch { border-radius: 999px; font-size: 12px; padding: 6px 14px; transition: 0.2s; }
    .btn-watch:hover { transform: scale(1.05); }

    .empty-box {
        text-align: center; padding: 70px;
        background: #16162a; border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.05);
        color: #9ca3af;
    }

    .empty-box h2 {
        font-weight: 800;
        background: linear-gradient(90deg, #f472b6, #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>

<div class="container mt-4">

    <h2 class="section-title">❤️ Beğendiğim Videolar</h2>

    @if (!Model.Any())
    {
        <div class="empty-box">
            <h2>Henüz beğendiğin video yok</h2>
            <p>Videoları izlerken 👍 butonuna basarak buraya ekleyebilirsin</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var video in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="video-card">

                        <!-- VIDEO -->
                        <video class="video-img" muted>
                            <source src="@video.VideoUrl" type="video/mp4" />
                        </video>

                        <!-- OVERLAY -->
                        <div class="overlay"><div class="play-icon">▶</div></div>

                        <!-- CONTENT -->
                        <div class="card-body">
                            <div class="video-title">@video.Baslik</div>
                            <div class="video-desc">@video.Aciklama</div>
                            <div class="video-meta">
                                👤 @video.Kullanici?.KullaniciAdi <br />
                                📅 @video.YuklenmeTarihi.ToString("dd MMM yyyy") <br />
                                👁 @video.IzlenmeSayisi • 👍 @video.LikeSayisi
                            </div>

                            <div class="mt-2 d-flex gap-2 flex-wrap">
                                <a asp-controller="Home" asp-action="Izle" asp-route-id="@video.Id" class="btn btn-outline-light btn-watch">▶ İzle</a>

                                <form asp-controller="Home" asp-action="DahaSonraEkle" asp-route-id="@video.Id" method="post">
                                    <button class="btn btn-outline-warning btn-watch">⏳ Listeye Ekle</button>
                                </form>

                                <!-- ✅ Beğenilerden Kaldır -->
                                <form asp-controller="Home" asp-action="BegenilerdenKaldir" asp-route-id="@video.Id" method="post">
                                    <button class="btn btn-outline-danger btn-watch">❌ Beğenilerden Kaldır</button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>
