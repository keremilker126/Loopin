@model Loopin.Models.Video

@{
    ViewData["Title"] = Model.Baslik;
}

<style>
    body {
        background: radial-gradient(circle at top, #141428, #0b0b14);
        color: white;
    }

    .main-container {
        display: flex;
        gap: 20px;
        margin-top: 20px;
    }

    .left-side { flex: 3; }
    .right-side { flex: 1; position: sticky; top: 20px; height: fit-content; }

    /* VIDEO */
    .video-box {
        border-radius: 18px;
        overflow: hidden;
        background: black;
        box-shadow: 0 15px 40px rgba(0,0,0,0.5);
    }

    /* INFO */
    .video-info {
        margin-top: 15px;
        background: #16162a;
        padding: 18px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .video-title {
        font-size: 20px;
        font-weight: 800;
        color: #f3f4f6;
    }

    .video-meta {
        font-size: 12px;
        color: #cbd5e1;
        margin-top: 8px;
    }

    .video-desc {
        font-size: 13px;
        color: #9ca3af;
        margin-top: 10px;
    }

    /* USER */
    .badge-user {
        margin-top: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
    }
    .btn-delete {
        border-radius: 999px;
        padding: 5px 12px;
        font-size: 12px;
        transition: 0.2s;
    }

    .btn-delete:hover {
        transform: scale(1.05);
        box-shadow: 0 0 10px rgba(239,68,68,0.6);
    }

    /* BUTTONS */
    .btn-like,
    .btn-modern {
        border-radius: 999px;
        font-size: 12px;
        padding: 6px 14px;
        transition: 0.2s;
    }

    .btn-like:hover,
    .btn-modern:hover {
        transform: scale(1.05);
    }

    /* COMMENTS */
    .yorum-box {
        background: #1a1a2e;
        padding: 12px;
        border-radius: 14px;
        margin-bottom: 10px;
        border: 1px solid rgba(255,255,255,0.05);
        transition: 0.2s;
    }

    .yorum-box:hover {
        transform: scale(1.01);
        background: #22223b;
    }

    textarea.form-control {
        border-radius: 12px;
        background: #16162a;
        color: white;
        border: 1px solid #333;
    }

    textarea.form-control:focus {
        background: #16162a;
        color: white;
        box-shadow: 0 0 0 2px rgba(168,85,247,0.3);
    }

    .comment-date {
        font-size: 11px;
        color: #9ca3af;
    }

    /* SUGGEST */
    .suggest-box {
        background: #16162a;
        padding: 15px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.05);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .suggest-item {
        display: flex;
        gap: 10px;
        margin-bottom: 12px;
        padding: 10px;
        border-radius: 14px;
        transition: 0.25s;
        align-items: center;
        cursor: pointer;
    }

    .suggest-item:hover {
        background: #22223b;
        transform: translateX(5px);
    }

    .suggest-thumb {
        width: 95px;
        height: 65px;
        object-fit: cover;
        border-radius: 10px;
    }

    .suggest-title {
        font-size: 12px;
        font-weight: 700;
        color: #f3f4f6;
    }

    .suggest-meta {
        font-size: 11px;
        color: #9ca3af;
    }

    /* RESPONSIVE */
    @@media (max-width: 992px) {
        .main-container { flex-direction: column; }
        .right-side { position: static; }
    }
</style>

<div class="container">

    <div class="main-container">

        <!-- LEFT SIDE -->
        <div class="left-side">

            <!-- VIDEO -->
            <div class="video-box">
                <video width="100%" controls>
                    <source src="@Model.VideoUrl" type="video/mp4" />
                </video>
            </div>

            <!-- INFO -->
            <div class="video-info">

                <div class="video-title">@Model.Baslik</div>

                <div class="video-meta">
                    👁 @Model.IzlenmeSayisi izlenme •
                    👍 @Model.LikeSayisi beğeni •
                    📅 @Model.YuklenmeTarihi.ToString("dd MMM yyyy HH:mm")
                </div>

                <!-- USER -->
                <div class="badge-user">

                    👤
                    <a asp-controller="Home"
                       asp-action="Kullanici"
                       asp-route-id="@Model.KullaniciId"
                       class="text-info">
                        @Model.Kullanici?.KullaniciAdi
                    </a>

                    @if (Context.Session.GetString("UserEmail") != null
                        && Context.Session.GetString("UserEmail") != Model.Kullanici?.Email)
                    {
                        <form asp-controller="Home"
                              asp-action="AbonelikToggle"
                              asp-route-id="@Model.KullaniciId"
                              method="post"
                              class="d-inline">

                            @if (ViewBag.AbonelikVar == true)
                            {
                                <button class="btn btn-outline-danger btn-like">
                                    Abonelikten Çık
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-outline-success btn-like">
                                    Abone Ol
                                </button>
                            }

                        </form>
                    }

                </div>

                <!-- DESC -->
                <div class="video-desc">@Model.Aciklama</div>

                <!-- LIKE -->
                <form asp-controller="Home"
                      asp-action="Begen"
                      asp-route-id="@Model.Id"
                      method="post"
                      class="mt-3">

                    @if (ViewBag.Begenildi == true)
                    {
                        <button class="btn btn-outline-danger btn-like">
                            👎 Beğeniyi Kaldır (@Model.LikeSayisi)
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-light btn-like">
                            👍 Beğen (@Model.LikeSayisi)
                        </button>
                    }

                </form>

                <!-- COMMENTS -->
                <div class="mt-4">

                    <h5>💬 Yorumlar</h5>

                    <form asp-controller="Home"
                          asp-action="YorumEkle"
                          asp-route-id="@Model.Id"
                          method="post">

                        <textarea name="Icerik"
                                  class="form-control mb-2"
                                  placeholder="Yorum yaz..."
                                  required></textarea>

                        <button class="btn btn-primary btn-modern">
                            Gönder
                        </button>

                    </form>

                    <div class="mt-3">

                        @if (Model.VideoYorumlar != null && Model.VideoYorumlar.Any())
                        {
                            foreach (var yorum in Model.VideoYorumlar)
                            {
                                <div class="yorum-box">

                                    <div class="d-flex justify-content-between">

                                        <div>
                                            <strong>@yorum.Kullanici?.KullaniciAdi</strong><br />
                                            <small class="comment-date">
                                                @yorum.Tarih.ToString("dd MMM yyyy HH:mm")
                                            </small>
                                        </div>

                                        @if (Context.Session.GetString("UserEmail") == yorum.Kullanici?.Email)
                                        {
                                            <form asp-controller="Home"
                                                asp-action="YorumSil"
                                                asp-route-id="@yorum.Id"
                                                method="post"
                                                onsubmit="return yorumSilOnay(event, this)">

                                            <button type="submit" class="btn btn-sm btn-danger btn-delete">
                                                🗑 Sil
                                            </button>

                                            </form>
                                        }

                                    </div>

                                    <p class="mt-2 mb-0">@yorum.Icerik</p>

                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted">Henüz yorum yok.</p>
                        }

                    </div>

                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="right-side">

            <div class="suggest-box">

                <h6 class="mb-3">🔥 Önerilen Videolar</h6>

                @if (ViewBag.DigerVideolar != null && ((List<Loopin.Models.Video>)ViewBag.DigerVideolar).Any())
                {
                    foreach (var v in (List<Loopin.Models.Video>)ViewBag.DigerVideolar)
                    {
                        <a asp-controller="Home"
                           asp-action="Izle"
                           asp-route-id="@v.Id"
                           style="text-decoration:none; color:inherit;">

                            <div class="suggest-item">

                                <img class="suggest-thumb" src="@v.KapakResmiUrl" />

                                <div>
                                    <div class="suggest-title">@v.Baslik</div>
                                    <div class="suggest-meta">
                                        👁 @v.IzlenmeSayisi izlenme <br />
                                        👍 @v.LikeSayisi
                                    </div>
                                </div>

                            </div>

                        </a>
                    }
                }
                else
                {
                    <p class="text-muted">Öneri bulunamadı</p>
                }

            </div>

        </div>

    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function yorumSilOnay(event, form) {
        event.preventDefault();

        Swal.fire({
            title: 'Yorumu silmek istiyor musun?',
            text: "Bu işlem geri alınamaz!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Evet, sil',
            cancelButtonText: 'Vazgeç',
            background: '#1a1a2e',
            color: 'white'
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });

        return false;
    }
</script>