@{
    ViewData["Title"] = "Şifre Değiştir";
}

<style>
    body {
        background: linear-gradient(135deg, #1a1a2e, #0f0f1a);
        min-height: 100vh;
        margin: 0;
    }

    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 90px;
        min-height: 100vh;
    }

    .auth-container {
        width: 100%;
        max-width: 420px;
        padding: 35px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        color: white;
        transition: 0.3s;
    }

    .auth-container:hover {
        transform: translateY(-10px);
    }

    .auth-title {
        text-align: center;
        margin-bottom: 25px;
        font-weight: 600;
        color: #c084fc;
    }

    .form-control {
        border-radius: 12px;
        background: #111827;
        border: none;
        color: white;
        padding: 10px;
    }

    .form-control:focus {
        box-shadow: 0 0 0 2px #6c63ff;
        background: #111827;
        color: white;
    }

    label {
        margin-bottom: 5px;
        font-size: 14px;
        color: #bbb;
    }

    .btn-auth {
        background: linear-gradient(45deg, #9333ea, #6366f1);
        border: none;
        width: 100%;
        padding: 12px;
        border-radius: 999px;
        color: white;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-auth:hover {
        transform: scale(1.05);
        opacity: 0.9;
    }

    .message {
        text-align: center;
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 15px;
        font-size: 14px;
    }

    .error {
        background: rgba(255, 0, 0, 0.15);
        color: #ff6b6b;
    }

    .success {
        background: rgba(0, 255, 100, 0.15);
        color: #4ade80;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-container">

        <h2 class="auth-title">🔒 Şifre Değiştir</h2>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="message error">
                ❌ @ViewBag.ErrorMessage
            </div>
        }

        @if (ViewBag.SuccessMessage != null)
        {
            <div class="message success">
                ✅ @ViewBag.SuccessMessage
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label>Eski Şifre</label>
                <input type="password" name="EskiSifre" class="form-control" placeholder="••••••••" required />
            </div>

            <div class="mb-3">
                <label>Yeni Şifre</label>
                <input type="password" name="YeniSifre" class="form-control" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn-auth">
                🔄 Şifreyi Güncelle
            </button>
        </form>

    </div>
</div>