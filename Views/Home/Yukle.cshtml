@{
    ViewData["Title"] = "Video Yükle";
}

<style>
    body {
        background: linear-gradient(135deg, #1a1a2e, #0f0f1a);
        color: white;
    }

    .upload-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 50px 15px;
    }

    .upload-container {
        width: 100%;
        max-width: 700px;
        padding: 30px;
        border-radius: 20px;
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(15px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .upload-title {
        text-align: center;
        font-weight: 600;
        color: #c084fc;
        margin-bottom: 25px;
    }

    label {
        font-size: 14px;
        color: #bbb;
        margin-bottom: 5px;
    }

    .form-control {
        border-radius: 12px;
        background: #111827;
        border: none;
        color: white;
        padding: 10px;
    }

    .form-control:focus {
        box-shadow: 0 0 0 2px #6c63ff;
        background: #111827;
        color: white;
    }

    .drop-zone {
        border: 2px dashed #6c63ff;
        border-radius: 15px;
        padding: 40px;
        text-align: center;
        cursor: pointer;
        transition: 0.3s;
        background: rgba(99,102,241,0.05);
    }

    .drop-zone:hover {
        background: rgba(99,102,241,0.1);
        transform: scale(1.02);
        box-shadow: 0 0 20px rgba(99,102,241,0.4);
    }

    .drop-zone input {
        display: none;
    }

    .preview {
        margin-top: 10px;
        font-size: 13px;
        color: #aaa;
        text-align: center;
    }

    .btn-upload {
        background: linear-gradient(45deg, #9333ea, #6366f1);
        border: none;
        width: 100%;
        padding: 12px;
        border-radius: 999px;
        color: white;
        font-weight: 600;
        transition: 0.3s;
        margin-top: 15px;
    }

    .btn-upload:hover {
        transform: scale(1.05);
        opacity: 0.9;
    }
</style>

<div class="upload-wrapper">
    <div class="upload-container">
        <h2 class="upload-title">🎬 Video Yükle</h2>

        <form method="post" enctype="multipart/form-data">

            <!-- BAŞLIK -->
            <div class="mb-3">
                <label>Video Başlık</label>
                <input type="text" name="Baslik" class="form-control" placeholder="Harika bir başlık yaz..." required />
            </div>

            <!-- AÇIKLAMA -->
            <div class="mb-3">
                <label>Açıklama</label>
                <textarea name="Aciklama" class="form-control" rows="3" placeholder="Videonu anlat..."></textarea>
            </div>

            <!-- KAPAK RESMİ -->
            <div class="mb-3">
                <label>Kapak Resmi Seç</label>
                <div class="drop-zone" onclick="document.getElementById('cover').click()">
                    🖼️ Resim seç veya buraya tıkla <br />
                    <small>(JPEG/PNG önerilir)</small>
                    <input type="file" id="cover" name="KapakResmi" accept="image/*" />
                </div>
                <div class="preview" id="coverName">Henüz resim seçilmedi</div>
            </div>

            <!-- VIDEO -->
            <div class="mb-3">
                <label>Video Dosyası</label>
                <div class="drop-zone" onclick="document.getElementById('file').click()">
                    📁 Video seç veya buraya tıkla <br />
                    <small>(MP4 önerilir)</small>
                    <input type="file" id="file" name="VideoDosya" accept="video/*" />
                </div>
                <div class="preview" id="fileName">Henüz dosya seçilmedi</div>
            </div>

            <button type="submit" class="btn-upload">🚀 Video Yükle</button>
        </form>
    </div>
</div>

<script>
    const fileInput = document.getElementById("file");
    const fileName = document.getElementById("fileName");
    const coverInput = document.getElementById("cover");
    const coverName = document.getElementById("coverName");

    fileInput.addEventListener("change", function () {
        if (this.files.length > 0) {
            fileName.innerHTML = "🎥 <b>" + this.files[0].name + "</b> seçildi";
        } else {
            fileName.innerText = "Henüz dosya seçilmedi";
        }
    });

    coverInput.addEventListener("change", function () {
        if (this.files.length > 0) {
            coverName.innerHTML = "🖼️ <b>" + this.files[0].name + "</b> seçildi";
        } else {
            coverName.innerText = "Henüz resim seçilmedi";
        }
    });
</script>
