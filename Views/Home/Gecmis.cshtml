@model List<Loopin.Models.Video>

<style>
    .section-title {
        font-weight: 600;
        margin-bottom: 20px;
        color: #c084fc;
    }

    .video-card {
        border-radius: 16px;
        overflow: hidden;
        background: #1a1a2e;
        transition: 0.3s;
    }

    .video-card:hover {
        transform: translateY(-6px) scale(1.02);
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    .video-img {
        height: 200px;
        width: 100%;
        object-fit: cover;
    }

    .card-body {
        padding: 15px;
    }

    .video-title {
        font-weight: 600;
        font-size: 15px;
        color: #e5e5e5;
        margin-bottom: 5px;
    }

    .video-meta {
        font-size: 12px;
        color: #888;
        margin-bottom: 12px;
    }

    .btn-custom {
        border-radius: 999px;
        font-size: 12px;
        padding: 5px 14px;
    }

    .empty-box {
        text-align: center;
        padding: 60px;
        background: #1a1a2e;
        border-radius: 20px;
        color: #aaa;
    }

    .empty-box h4 {
        color: #a855f7;
    }
</style>

<div class="container mt-4">

    <h3 class="section-title">📜 İzleme Geçmişi</h3>

    @if (!Model.Any())
    {
        <div class="empty-box">
            <h4>Henüz izleme geçmişin yok</h4>
            <p>Videolar izledikçe burada görünecek 🎬</p>
        </div>
    }
    else
    {
        <!-- TOPLU TEMİZLE -->
        <form asp-controller="Home" asp-action="GecmisTemizle" method="post" class="mb-3">
            <button class="btn btn-outline-danger btn-custom">
                🗑 Tümünü Temizle
            </button>
        </form>

        <div class="row g-4">

            @foreach (var video in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">

                    <div class="video-card">

                        <!-- VIDEO -->
                        <video class="video-img" muted>
                            <source src="@video.VideoUrl" type="video/mp4" />
                        </video>

                        <div class="card-body">

                            <div class="video-title">
                                @video.Baslik
                            </div>

                            <div class="video-meta">
                                👁 @video.IzlenmeSayisi • 👍 @video.LikeSayisi
                            </div>

                            <!-- BUTONLAR -->
                            <div class="d-flex justify-content-between align-items-center">

                                <!-- İZLE -->
                                <a asp-controller="Home"
                                   asp-action="Izle"
                                   asp-route-id="@video.Id"
                                   class="btn btn-outline-light btn-custom">
                                    ▶ İzle
                                </a>

                                <!-- SİL -->
                                <form asp-controller="Home"
                                      asp-action="GecmisSil"
                                      asp-route-id="@video.Id"
                                      method="post">
                                    <button type="submit" class="btn btn-danger btn-custom">
                                        ❌ Sil
                                    </button>
                                </form>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>