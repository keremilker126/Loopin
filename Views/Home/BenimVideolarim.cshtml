@model List<Loopin.Models.Video>

@{
    ViewData["Title"] = "Benim Videolarım";
}

<style>
    body { background-color: #0f0f1a; color: white; }

    .section-title {
        margin-bottom: 25px;
        font-weight: 600;
        color: #c084fc;
    }

    .video-card {
        border-radius: 16px;
        overflow: hidden;
        background: #1a1a2e;
        transition: 0.3s;
        position: relative;
    }

    .video-card:hover {
        transform: translateY(-6px) scale(1.02);
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    .video-img {
        height: 200px;
        width: 100%;
        object-fit: cover;
        transition: 0.3s;
    }

    .video-card:hover .video-img {
        transform: scale(1.08);
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 200px;
        background: rgba(0,0,0,0.4);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: 0.3s;
    }

    .video-card:hover .overlay {
        opacity: 1;
    }

    .play-icon {
        font-size: 40px;
        color: white;
    }

    .card-body {
        padding: 15px;
    }

    .video-title {
        font-weight: 600;
        font-size: 16px;
        color: #e5e5e5;
    }

    .video-desc {
        font-size: 13px;
        color: #aaa;
        height: 40px;
        overflow: hidden;
    }

    .video-meta {
        font-size: 12px;
        color: #888;
        margin-top: 8px;
    }

    .btn-watch, .btn-delete {
        border-radius: 999px;
        font-size: 12px;
        padding: 5px 12px;
        transition: 0.2s;
    }

    .btn-watch:hover, .btn-delete:hover {
        transform: scale(1.05);
    }

    .empty-box {
        text-align: center;
        padding: 80px 20px;
        background: #1a1a2e;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .empty-box h2 {
        color: #a855f7;
    }

    /* MODAL */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(6px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-box {
        background: #1a1a2e;
        padding: 25px;
        border-radius: 16px;
        text-align: center;
        width: 320px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.1);
        animation: pop .2s ease-in-out;
    }

    .modal-box h3 {
        color: #f87171;
    }

    .modal-box p {
        color: #aaa;
        font-size: 14px;
    }

    .modal-actions {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
        gap: 10px;
    }

    @@keyframes pop {
        from { transform: scale(0.8); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
</style>

<div class="container mt-4">

    <h2 class="section-title">📂 Benim Videolarım</h2>

    @if (!Model.Any())
    {
        <div class="empty-box">
            <h2>Henüz video yüklemediniz</h2>
            <p>İlk videonu yükleyerek başlayabilirsin 🚀</p>
            <a asp-controller="Home" asp-action="Yukle" class="btn btn-primary btn-watch">
                🎬 Video Yükle
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var video in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">

                    <div class="video-card">

                        <video class="video-img" muted>
                            <source src="@video.VideoUrl" type="video/mp4" />
                        </video>

                        <div class="overlay">
                            <div class="play-icon">▶</div>
                        </div>

                        <div class="card-body">

                            <div class="video-title">@video.Baslik</div>

                            <div class="video-desc">@video.Aciklama</div>

                            <div class="video-meta">
                                📅 @video.YuklenmeTarihi.ToString("dd MMM yyyy") <br />
                                👁 @video.IzlenmeSayisi | 👍 @video.LikeSayisi
                            </div>

                            <div class="mt-3 d-flex justify-content-between">

                                <a href="/Home/Izle/@video.Id" class="btn btn-outline-light btn-watch">
                                    ▶ İzle
                                </a>

                                <form asp-controller="Home"
                                      asp-action="VideoSil"
                                      asp-route-id="@video.Id"
                                      method="post"
                                      onsubmit="return openDeleteModal(this);">

                                    <button type="submit" class="btn btn-danger btn-delete">
                                        🗑 Sil
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

<!-- MODAL -->
<div id="deleteModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">

        <h3>⚠️ Emin misin?</h3>
        <p>Bu video kalıcı olarak silinecek.</p>

        <div class="modal-actions">
            <button id="cancelBtn" class="btn btn-secondary">Vazgeç</button>
            <button id="confirmBtn" class="btn btn-danger">Evet, Sil</button>
        </div>

    </div>
</div>

<script>
    let currentForm = null;

    function openDeleteModal(form) {
        currentForm = form;
        document.getElementById("deleteModal").style.display = "flex";
        return false;
    }

    document.getElementById("cancelBtn").onclick = function () {
        document.getElementById("deleteModal").style.display = "none";
        currentForm = null;
    };

    document.getElementById("confirmBtn").onclick = function () {
        if (currentForm) {
            currentForm.submit();
        }
    };
</script>